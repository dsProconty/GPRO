# ─── Base de Datos (Neon PostgreSQL) ───────────────────────────────────────────
# Obtén este valor desde: neon.com → tu proyecto → Connection string
DATABASE_URL="postgresql://gpro_owner:PASSWORD@ep-XXXXX.us-east-2.aws.neon.tech/gpro?sslmode=require"

# ─── NextAuth ──────────────────────────────────────────────────────────────────
# Genera uno con: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secreto-aqui-generado-con-openssl"
# En desarrollo:
NEXTAUTH_URL="http://localhost:3000"
# En producción Vercel: se configura automáticamente, no necesitas ponerlo

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="GPRO - Gestor de Proyectos"
NEXT_PUBLIC_APP_VERSION="1.0.0"
